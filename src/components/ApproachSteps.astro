---
import { approach } from '../content/home';
---

<section id="approach" class="px-6 py-28 md:py-36">
  <div class="max-w-[1200px] mx-auto">
    <!-- Eyebrow -->
    <p
      class="font-mono text-[11px] uppercase tracking-[0.12em] mb-4"
      style="color: var(--accent);"
    >
      {approach.eyebrow}
    </p>

    <!-- Heading -->
    <h2 class="font-sans text-2xl md:text-3xl font-semibold tracking-tight mb-12">
      {approach.headline}
    </h2>

    <!-- Steps -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-6">
      {approach.steps.map((step, i) => (
        <div class="relative">
          {/* Separator on desktop (not on first) */}
          {i > 0 && (
            <div
              class="hidden lg:block absolute -left-3 top-0 bottom-0 w-px"
              style="background: var(--card-border);"
            />
          )}

          <!-- Number -->
          <p class="font-mono text-[13px] font-medium mb-2" style="color: var(--accent);">
            {step.number}
          </p>

          <!-- Title -->
          <h3 class="font-sans text-base font-semibold tracking-tight mb-2">
            {step.title}
          </h3>

          <!-- Description -->
          <p class="font-sans text-[14px] leading-relaxed" style="color: var(--text-2);">
            {step.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
