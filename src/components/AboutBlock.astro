---
import { about } from '../content/home';
import { LINKEDIN_URL } from '../content/siteConfig';
---

<section id="about" class="rv px-6 py-28 md:py-36">
  <div class="max-w-[720px] mx-auto">
    <!-- Eyebrow -->
    <p
      class="font-mono text-[11px] uppercase tracking-[0.12em] mb-8"
      style="color: var(--accent);"
    >
      {about.eyebrow}
    </p>

    <!-- Headshot -->
    <div
      class="w-40 h-40 md:w-48 md:h-48 rounded-2xl overflow-hidden border mb-8"
      style="border-color: var(--card-border); box-shadow: 0 20px 60px -12px rgba(0,0,0,0.15);"
    >
      <img
        src="/headshot.jpg"
        alt="Brendan Lee"
        class="w-full h-full object-cover"
      />
    </div>

    <!-- Statements -->
    <div class="space-y-6 mb-10">
      {about.statements.map((statement) => (
        <p class="font-sans text-[16px] md:text-[17px] leading-relaxed">
          {statement}
        </p>
      ))}
    </div>

    <!-- Creative work -->
    <p class="text-[14px] leading-relaxed mb-2" style="color: var(--text-2);">
      {about.creative}
    </p>
    <div class="flex flex-wrap gap-4">
      <a
        href={about.instagram}
        target="_blank"
        rel="noopener noreferrer"
        class="font-sans text-[13px] font-medium transition-opacity hover:opacity-70"
        style="color: var(--accent);"
      >
        Instagram ({about.instagramFollowers})
      </a>
      <a
        href={LINKEDIN_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="font-sans text-[13px] font-medium transition-opacity hover:opacity-70"
        style="color: var(--accent);"
      >
        LinkedIn
      </a>
    </div>
  </div>
</section>
