---
import { LINKEDIN_URL } from '../content/siteConfig';
---

<footer class="border-t py-8 px-6" style="border-color: var(--card-border);">
  <div class="max-w-[1200px] mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
    <p class="font-sans text-[12px] tracking-wide" style="color: var(--text-3);">
      &copy; 2026 Information Logistics LLC
    </p>
    <a
      href={LINKEDIN_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="font-sans text-[12px] tracking-wide transition-colors hover:opacity-70"
      style="color: var(--text-2);"
    >
      LinkedIn
    </a>
  </div>
</footer>
